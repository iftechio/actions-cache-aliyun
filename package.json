{
  "name": "cache",
  "version": "3.3.1",
  "private": true,
  "description": "Cache dependencies and build outputs",
  "main": "dist/restore/index.js",
  "scripts": {
    "build": "tsc && ncc build -o dist/restore src/restore.ts && ncc build -o dist/save src/save.ts && ncc build -o dist/restore-only src/restoreOnly.ts && ncc build -o dist/save-only src/saveOnly.ts",
    "test": "tsc --noEmit && jest --coverage",
    "lint": "eslint **/*.ts --cache",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iftechio/actions-cache-aliyun.git"
  },
  "keywords": [
    "actions",
    "node",
    "cache"
  ],
  "author": "GitHub",
  "license": "MIT",
  "dependencies": {
    "@actions/cache": "file:packages/cache",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/glob": "^0.4.0",
    "@actions/http-client": "^2.2.3",
    "@actions/io": "^1.1.3",
    "@aws-sdk/client-s3": "^3.51.0",
    "@aws-sdk/types": "^3.50.0"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "nock": "^13.5.6",
    "prettier": "^3.6.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.35.0"
  }
}
